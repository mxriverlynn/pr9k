#!/bin/bash
set -e

# INSPIRED BY https://github.com/openclaw/skills/tree/main/skills/tunaissacoding/claude-oauth-refresher

CLAUDE_PATH=${CLAUDE_CONFIG_DIR:-"$HOME/.claude"}
CONFIG_FILE="$CLAUDE_PATH/credentials.json"

# CLIENT_ID: OAuth client ID hardcoded into the official claude CLI for 
# talking to console.anthropic.com's OAuth endpoint — a public client 
# identifier (not a secret) that Anthropic's CLI ships with. 
CLIENT_ID="9d1c250a-e61b-44d9-88ed-5944d1962f5e"

TOKEN_URL="https://console.anthropic.com/v1/oauth/token"
REFRESH_BUFFER_MS=$((10 * 60 * 1000)) # 10 minutes

log() {
    echo "[get_claude_credentials] $1"
}

err() {
    echo "[get_claude_credentials] ERROR: $1" >&2
}

# Step 1: seed credentials.json from the macOS keychain when the file is missing.
seed_from_keychain() {
    log "credentials.json not found at $CONFIG_FILE; seeding from keychain"
    local credentials
    credentials=$(security find-generic-password -s "Claude Code-credentials" -w)
    mkdir -p "$CLAUDE_PATH"
    echo "$credentials" > "$CONFIG_FILE"
    log "wrote seed credentials to $CONFIG_FILE"
}

# Step 2: read the expiration timestamp (epoch ms) from credentials.json.
read_expiration() {
    EXPIRES_AT=$(jq -r '.claudeAiOauth.expiresAt // 0' "$CONFIG_FILE")
    NOW_MS=$(($(date +%s) * 1000))
    TIME_LEFT_MS=$((EXPIRES_AT - NOW_MS))
    local minutes=$((TIME_LEFT_MS / 60000))
    log "credentials expire in ${minutes} minute(s)"
}

# Step 3: decide whether the access token needs refreshing.
needs_refresh() {
    if [[ $TIME_LEFT_MS -gt $REFRESH_BUFFER_MS ]]; then
        log "token still valid; skipping refresh"
        return 1
    fi
    log "token expires within $((REFRESH_BUFFER_MS / 60000)) minute(s); refresh required"
    return 0
}

# Step 4: hit the OAuth endpoint with the stored refresh token.
refresh_oauth_token() {
    local refresh_token
    refresh_token=$(jq -r '.claudeAiOauth.refreshToken // empty' "$CONFIG_FILE")
    if [[ -z "$refresh_token" ]]; then
        err "no refreshToken in $CONFIG_FILE"
        exit 1
    fi

    log "calling OAuth refresh endpoint at $TOKEN_URL"
    local response
    response=$(curl -s -X POST "$TOKEN_URL" \
        -H "Content-Type: application/json" \
        --max-time 30 \
        -d "{\"grant_type\": \"refresh_token\", \"refresh_token\": \"$refresh_token\", \"client_id\": \"$CLIENT_ID\"}")

    NEW_ACCESS=$(echo "$response" | jq -r '.access_token // empty')
    NEW_REFRESH=$(echo "$response" | jq -r '.refresh_token // empty')
    local expires_in
    expires_in=$(echo "$response" | jq -r '.expires_in // 0')

    if [[ -z "$NEW_ACCESS" || -z "$NEW_REFRESH" || "$expires_in" -eq 0 ]]; then
        err "invalid OAuth response (missing access_token, refresh_token, or expires_in)"
        exit 1
    fi

    NEW_EXPIRES_AT=$(($(date +%s) * 1000 + expires_in * 1000))
    log "received new tokens; expires_in=${expires_in}s"
}

# Step 5: write the refreshed tokens back into $CONFIG_FILE, preserving other fields.
write_refreshed_credentials() {
    log "writing refreshed credentials to $CONFIG_FILE"
    local tmpfile
    tmpfile=$(mktemp "$CONFIG_FILE.XXXXXX")
    jq --arg access "$NEW_ACCESS" \
       --arg refresh "$NEW_REFRESH" \
       --argjson expires "$NEW_EXPIRES_AT" \
       '.claudeAiOauth.accessToken = $access
        | .claudeAiOauth.refreshToken = $refresh
        | .claudeAiOauth.expiresAt = $expires' \
       "$CONFIG_FILE" > "$tmpfile"
    mv "$tmpfile" "$CONFIG_FILE"
    log "credentials updated"
}

main() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        seed_from_keychain
        exit 0
    fi

    read_expiration
    if ! needs_refresh; then
        exit 0
    fi

    refresh_oauth_token
    write_refreshed_credentials
}

main
