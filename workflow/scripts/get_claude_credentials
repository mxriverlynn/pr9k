#!/bin/bash
set -e

# This script is wired into the workflow as a non-fatal best-effort step:
# a missing keychain entry, expired refresh token, network blip, or OAuth
# server error must not abort the calling workflow. Errors are still logged
# via err()/log() so they remain visible, but the EXIT trap forces a 0 exit
# code regardless of how (or where) the script terminated.
trap 'exit 0' EXIT

# INSPIRED BY https://github.com/openclaw/skills/tree/main/skills/tunaissacoding/claude-oauth-refresher

CLAUDE_PATH=${CLAUDE_CONFIG_DIR:-"$HOME/.claude"}
CONFIG_FILE="$CLAUDE_PATH/.credentials.json"

# CLIENT_ID: OAuth client ID hardcoded into the official claude CLI for
# talking to the Anthropic OAuth endpoint — a public client identifier
# (not a secret) that Anthropic's CLI ships with. Verified against the
# published @anthropic-ai/claude-code v2.1.123 binary (2026-04-30).
CLIENT_ID="9d1c250a-e61b-44d9-88ed-5944d1962f5e"

TOKEN_URL="https://console.anthropic.com/v1/oauth/token"
REFRESH_BUFFER_MS=$((10 * 60 * 1000)) # 10 minutes

# Cooldown file used to honor server-side Retry-After. Per-user (uid) so it
# doesn't collide on multi-user hosts. Path under /tmp because this is
# transient state, not workflow output.
COOLDOWN_FILE="/tmp/.pr9k-oauth-cooldown-$(id -u)"

# Floor on the cooldown duration. Anthropic's OAuth-class 429s frequently
# return Retry-After: 0 (see anthropics/claude-code#30930), which is too
# aggressive — treat any 429 as at least a 60-second cooldown to break
# the retry-amplification cycle.
COOLDOWN_FLOOR_SECONDS=60

log() {
    echo "[get_claude_credentials] $1"
}

err() {
    echo "[get_claude_credentials] ERROR: $1" >&2
}

# Step 1: seed .credentials.json from the macOS keychain when the file is missing.
seed_from_keychain() {
    log ".credentials.json not found at $CONFIG_FILE; seeding from keychain"

    # Claude Code stores OAuth tokens under "Claude Code-credentials-<hash>",
    # where <hash> is the first 8 hex chars of sha256(<profile path>). That
    # makes the entry unambiguous per profile, so a host with multiple
    # CLAUDE_CONFIG_DIR profiles (e.g. ~/.claude and ~/.claude-testdouble)
    # never crosses tokens between them.
    #
    # We don't know whether Claude Code hashed the path as-given or the
    # symlink-resolved form, so try both. Strip trailing slashes to match the
    # exact form Claude Code uses. realpath fails on non-existent paths on
    # macOS (BSD realpath has no -m), so we tolerate failure and still try
    # the as-given form.
    local raw_path="${CLAUDE_PATH%/}"
    local resolved_path=""
    resolved_path=$(realpath "$CLAUDE_PATH" 2>/dev/null || true)
    resolved_path="${resolved_path%/}"

    local candidates=("$raw_path")
    if [[ -n "$resolved_path" && "$resolved_path" != "$raw_path" ]]; then
        candidates+=("$resolved_path")
    fi

    # Search across candidate paths for the first keychain entry that holds
    # valid OAuth tokens. Validate inside the loop so we don't stop early on a
    # malformed entry when a second candidate would have worked.
    local service="" data="" profile_hash="" expires="" refresh=""
    local found_service="" found_data="" found_expires=""
    for candidate in "${candidates[@]}"; do
        profile_hash=$(printf '%s' "$candidate" | shasum -a 256 | cut -c1-8)
        service="Claude Code-credentials-$profile_hash"
        log "trying keychain entry: $service (from path '$candidate')"
        data=$(security find-generic-password -s "$service" -w 2>/dev/null || true)
        [[ -z "$data" ]] && continue
        expires=$(echo "$data" | jq -r '.claudeAiOauth.expiresAt // 0' 2>/dev/null || echo 0)
        refresh=$(echo "$data" | jq -r '.claudeAiOauth.refreshToken // ""' 2>/dev/null || echo "")
        if [[ -z "$refresh" || "$expires" -eq 0 ]]; then
            log "entry '$service' did not contain valid OAuth tokens; trying next candidate"
            continue
        fi
        found_service="$service"
        found_data="$data"
        found_expires="$expires"
        break
    done

    if [[ -z "$found_data" ]]; then
        err "no keychain entry with valid OAuth tokens found for profile '$raw_path'; run 'claude' on this host first"
        exit 1
    fi

    data="$found_data"
    log "selected keychain entry: $found_service (expiresAt=$found_expires)"

    mkdir -p "$CLAUDE_PATH"
    echo "$data" > "$CONFIG_FILE"
    log "wrote seed credentials to $CONFIG_FILE"
}

# Step 2: read the expiration timestamp (epoch ms) from .credentials.json.
read_expiration() {
    EXPIRES_AT=$(jq -r '.claudeAiOauth.expiresAt // 0' "$CONFIG_FILE")
    NOW_MS=$(($(date +%s) * 1000))
    TIME_LEFT_MS=$((EXPIRES_AT - NOW_MS))
    local minutes=$((TIME_LEFT_MS / 60000))
    log "credentials expire in ${minutes} minute(s)"
}

# Step 3: decide whether the access token needs refreshing.
needs_refresh() {
    if [[ $TIME_LEFT_MS -gt $REFRESH_BUFFER_MS ]]; then
        log "token still valid; skipping refresh"
        return 1
    fi
    log "token expires within $((REFRESH_BUFFER_MS / 60000)) minute(s); refresh required"
    return 0
}

# Check whether a prior 429 placed us in cooldown. Returns 0 if we should
# skip the refresh attempt, 1 if it's safe to proceed.
in_cooldown() {
    [[ ! -f "$COOLDOWN_FILE" ]] && return 1
    local deadline now wait
    deadline=$(cat "$COOLDOWN_FILE" 2>/dev/null || echo 0)
    now=$(date +%s)
    if [[ "$now" -lt "$deadline" ]]; then
        wait=$((deadline - now))
        log "in OAuth refresh cooldown for ${wait} more second(s); skipping refresh attempt"
        return 0
    fi
    rm -f "$COOLDOWN_FILE"
    return 1
}

# Step 4: hit the OAuth endpoint with the stored refresh token.
refresh_oauth_token() {
    local refresh_token
    refresh_token=$(jq -r '.claudeAiOauth.refreshToken // empty' "$CONFIG_FILE")
    if [[ -z "$refresh_token" ]]; then
        err "no refreshToken in $CONFIG_FILE"
        exit 1
    fi

    log "calling OAuth refresh endpoint at $TOKEN_URL"

    # Capture body, headers, and HTTP status separately so non-2xx responses
    # (rate limits, auth errors, server errors) surface with full diagnostic
    # context. mktemp creates 0600 files on macOS so the token written to disk
    # is private to the user.
    local body_file headers_file http_code
    body_file=$(mktemp)
    headers_file=$(mktemp)
    http_code=$(curl -s -o "$body_file" -D "$headers_file" -w '%{http_code}' -X POST "$TOKEN_URL" \
        -H "Content-Type: application/json" \
        --max-time 30 \
        -d "{\"grant_type\": \"refresh_token\", \"refresh_token\": \"$refresh_token\", \"client_id\": \"$CLIENT_ID\"}")

    if [[ "$http_code" != "200" ]]; then
        err "OAuth refresh failed (HTTP $http_code)"

        # Diagnostic response headers — cf-ray and cf-mitigated distinguish
        # Cloudflare WAF blocks from Anthropic application-layer rate limits;
        # server: indicates whether the response came from Cloudflare or the
        # upstream; Retry-After is honored below to break the retry cycle.
        local cf_ray cf_mitigated server retry_after_raw
        cf_ray=$(grep -i '^cf-ray:' "$headers_file" | head -1 | tr -d '\r' || true)
        cf_mitigated=$(grep -i '^cf-mitigated:' "$headers_file" | head -1 | tr -d '\r' || true)
        server=$(grep -i '^server:' "$headers_file" | head -1 | tr -d '\r' || true)
        retry_after_raw=$(grep -i '^retry-after:' "$headers_file" | head -1 | tr -d '\r' || true)
        [[ -n "$cf_ray" ]] && err "diagnostic: $cf_ray"
        [[ -n "$cf_mitigated" ]] && err "diagnostic: $cf_mitigated"
        [[ -n "$server" ]] && err "diagnostic: $server"
        [[ -n "$retry_after_raw" ]] && err "diagnostic: $retry_after_raw"

        # On 429, write a cooldown deadline so subsequent invocations skip the
        # refresh until the server says we're allowed back. Floor at
        # COOLDOWN_FLOOR_SECONDS because Anthropic frequently returns
        # Retry-After: 0 on OAuth-class 429s, which would defeat the cooldown.
        if [[ "$http_code" == "429" ]]; then
            local seconds=0
            if [[ -n "$retry_after_raw" ]]; then
                seconds=$(echo "$retry_after_raw" | sed -n 's/^[Rr]etry-[Aa]fter:[[:space:]]*\([0-9]*\).*/\1/p')
                [[ -z "$seconds" ]] && seconds=0
            fi
            if [[ "$seconds" -lt "$COOLDOWN_FLOOR_SECONDS" ]]; then
                seconds="$COOLDOWN_FLOOR_SECONDS"
            fi
            local deadline=$(($(date +%s) + seconds))
            echo "$deadline" > "$COOLDOWN_FILE"
            err "wrote cooldown until $(date -r "$deadline" 2>/dev/null || echo "$deadline") (${seconds}s)"
        fi

        # Allowlist only RFC 6749 §5.2 error fields. Anything else (including
        # any future field that might echo credentials back) is dropped.
        local body_view
        body_view=$(jq -c '{error: .error, error_description: .error_description}' "$body_file" 2>/dev/null) || body_view=""
        if [[ -n "$body_view" ]]; then
            # Belt-and-suspenders: scrub the live refresh token in case it ever
            # appears in error_description.
            body_view=${body_view//$refresh_token/<redacted>}
            err "response body: $body_view"
        else
            err "response body (non-JSON, first 500 bytes): $(head -c 500 "$body_file" | tr -cd '[:print:]\n')"
        fi
        rm -f "$body_file" "$headers_file"
        exit 1
    fi

    NEW_ACCESS=$(jq -r '.access_token // empty' "$body_file")
    NEW_REFRESH=$(jq -r '.refresh_token // empty' "$body_file")
    local expires_in
    expires_in=$(jq -r '(.expires_in // 0) | floor' "$body_file")
    rm -f "$body_file" "$headers_file"

    # Per RFC 6749 §6, the authorization server MAY but is not required to
    # issue a new refresh token. Fall back to the existing one when absent.
    NEW_REFRESH=${NEW_REFRESH:-$refresh_token}

    if [[ -z "$NEW_ACCESS" || "$expires_in" -eq 0 ]]; then
        err "OAuth response (HTTP 200) did not contain expected access_token or expires_in fields"
        exit 1
    fi

    NEW_EXPIRES_AT=$(($(date +%s) * 1000 + expires_in * 1000))
    log "received new tokens; expires_in=${expires_in}s"
}

# Step 5: write the refreshed tokens back into $CONFIG_FILE, preserving other fields.
write_refreshed_credentials() {
    log "writing refreshed credentials to $CONFIG_FILE"
    local tmpfile
    tmpfile=$(mktemp "$CONFIG_FILE.XXXXXX")
    jq --arg access "$NEW_ACCESS" \
       --arg refresh "$NEW_REFRESH" \
       --argjson expires "$NEW_EXPIRES_AT" \
       '.claudeAiOauth.accessToken = $access
        | .claudeAiOauth.refreshToken = $refresh
        | .claudeAiOauth.expiresAt = $expires' \
       "$CONFIG_FILE" > "$tmpfile"
    mv "$tmpfile" "$CONFIG_FILE"
    log "credentials updated"
}

main() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        seed_from_keychain
        exit 0
    fi

    read_expiration
    if ! needs_refresh; then
        exit 0
    fi

    if in_cooldown; then
        exit 0
    fi

    refresh_oauth_token
    write_refreshed_credentials
}

main
